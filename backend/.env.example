# Copia in `.env` e inserisci la tua chiave per usare Claude reale.
# Senza chiave il backend gira comunque in modalità "fallback" (deterministica).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Governance (opzionali — questi sono i default)
CONFIDENCE_THRESHOLD=60
RETRIEVAL_K=4
MINUTES_SAVED_PER_QUERY=15
